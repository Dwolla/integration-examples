# Dwolla Environment and Client Key and Secret
# https://dashboard-sandbox.dwolla.com/applications-legacy
DWOLLA_ENV=sandbox
DWOLLA_KEY=your_dwolla_key
DWOLLA_SECRET=your_dwolla_secret

# Checkout.com client-side environment variables
NEXT_PUBLIC_CKO_ENV=sandbox
NEXT_PUBLIC_CKO_PUBLIC_KEY=pk_sbox_your_public_key

# App base URL used in redirects/callbacks (optional - defaults to localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000