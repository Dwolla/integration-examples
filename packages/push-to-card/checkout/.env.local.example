# Next.js client env: only variables prefixed with NEXT_PUBLIC_ are available in the browser.
# Do NOT prefix secrets that should stay server-side.

# Dwolla Environment and Client Key and Secret
# https://dashboard-sandbox.dwolla.com/applications-legacy
# For Production
# DWOLLA_ENV=prod
DWOLLA_ENV=sandbox 
DWOLLA_KEY=...
DWOLLA_SECRET=...

# Checkout.com API Endpoint, Public Key and Secret Key.
# Contact Checkout.com (https://dashboard.sandbox.checkout.com/support/) for more information on how to obtained these values

# Client (browser) – required
NEXT_PUBLIC_CKO_PUBLIC_KEY=pk_sbox_...
NEXT_PUBLIC_CKO_ENV=sandbox

# Server-only – required
CKO_SECRET_KEY=sk_sbox_...
CKO_PROCESSING_CHANNEL_ID=pc_...
CKO_CLIENT_ID=cli_...      # optional if using host prefixing